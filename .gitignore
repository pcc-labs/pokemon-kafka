# ROM files (legally obtained, not for distribution)
rom/

# Emulator save data
*.ram
*.sav
*.state

# Screenshot output
frames/

# Tapes telemetry (SQLite DB + local config)
.tapes/

# Plans (ephemeral working artifacts, never commit)
docs/plans/
docs/superpowers/

# Agent working memory (ephemeral per-run notes)
notes.md

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# Environment / secrets
.env
*.key
api-key-*.txt

# Config (may contain credential env var references)
config.toml

# Claude Code (user-specific)
.claude/

# Git worktrees
.worktrees/

# Test artifacts
.coverage
.pytest_cache/

# Pokedex session logs (log7+ are local-only run artifacts)
pokedex/log[7-9]*.md
pokedex/log1[0-9]*.md
pokedex/log2[0-9]*.md

# Generated results
pokedex/evolve_results.json

# Telemetry data (generated at runtime)
data/telemetry/*.jsonl

# DuckDB warehouse files
data/*.duckdb
data/*.duckdb.wal

# dlt pipeline state
.dlt/

# Docker
docker-compose.override.yml
