# ROM files (legally obtained, not for distribution)
rom/

# Emulator save data
*.ram
*.sav
*.state

# Screenshot output
frames/

# Observer memory output (per-run observations + watermark)
pokedex/memory/

# Leftover local Tapes telemetry (project migrated to Paper)
.tapes/

# Plans (ephemeral working artifacts, never commit)
docs/plans/

# Agent working memory (ephemeral per-run notes)
notes.md

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# Environment / secrets
.env
*.key

# Claude Code (user-specific)
.claude/

# Test artifacts
.coverage
.pytest_cache/

# Pokedex session logs: log1-6 are committed as examples, everything
# else is local-only run output (users do their own training runs).
pokedex/log*.md
