# ROM files (legally obtained, not for distribution) — keep the dir, never its contents
rom/*
!rom/.gitkeep

# Generated agent run data (frames, events, summaries)
runs/

# Emulator save data
*.ram
*.sav
*.state

# Screenshot output
frames/

# Observer memory output (per-run observations + watermark)
pokedex/memory/

# Plans (ephemeral working artifacts, never commit)
docs/plans/
docs/superpowers/

# Agent working memory (ephemeral per-run notes)
notes.md

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# Environment / secrets
.env
*.key
api-key-*.txt

# Config (may contain credential env var references)
config.toml

# Claude Code (user-specific)
.claude/

# Git worktrees
.worktrees/

# Test artifacts
.coverage
.pytest_cache/

# Pokedex session logs: log1-6 are committed as examples, everything
# else is local-only run output (users do their own training runs).
pokedex/log*.md
!pokedex/log1.md
!pokedex/log2.md
!pokedex/log3.md
!pokedex/log4.md
!pokedex/log5.md
!pokedex/log6.md

# Generated results
pokedex/evolve_results.json

# Telemetry data (generated at runtime)
data/telemetry/*.jsonl
data/telemetry/game/

# Local agent run output (per-run logs, telemetry, states)
data/quest_run*/
data/dbg/

# DuckDB warehouse files
data/*.duckdb
data/*.duckdb.wal

# dlt pipeline state
.dlt/

# Docker
docker-compose.override.yml

# Committed replayable demo runs (frames + events), but NOT the generated states.
# The bare `frames/` rule above matches at any depth, so re-include demo-runs first.
!demo-runs/
!demo-runs/**
demo-runs/states/
